# Copia este archivo a ".env" y rellena tus valores reales.
# El archivo .env NUNCA se sube a git (ver .gitignore).

# --- Telegram ---
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=987654321

# (La app es 100% determinista: ya NO usa OpenAI, no hace falta ninguna clave de IA.)

# --- Monitoreo ---
# Cada cuanto revisa la watchlist (segundos). 300 = 5 min.
CHECK_INTERVAL_SECONDS=300
# Anti-spam: minimo entre alertas del mismo ticker (segundos). 900 = 15 min.
ALERT_COOLDOWN_SECONDS=900
